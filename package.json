{
  "name": "mantle-OfflineMediaDownloader",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.27.0"
  },
  "packageManager": "pnpm@10.27.0",
  "type": "module",
  "scripts": {
    "adr:new": "./bin/adr-new.sh",
    "audit": "pnpm audit --audit-level=high",
    "audit:aws": "./bin/aws-audit.sh",
    "audit:aws:production": "./bin/aws-audit.sh --env production",
    "audit:aws:staging": "./bin/aws-audit.sh --env staging",
    "audit:fix": "pnpm audit --fix",
    "build": "./bin/decrypt-cookies.sh && mantle build",
    "build:bgutil:layer": "./bin/build-bgutil-layer.sh",
    "cookies:encrypt": "sops encrypt --input-type binary --output-type binary --filename-override youtube-cookies.enc layers/yt-dlp/cookies/youtube-cookies.txt > layers/yt-dlp/cookies/youtube-cookies.enc",
    "check:secrets": "./bin/check-secrets.sh",
    "check:test:types": "tsc --project ./tsconfig.test.json --noEmit",
    "check:types": "tsc --project ./tsconfig.json",
    "cleanup": "./bin/cleanup.sh",
    "cleanup:check": "./bin/cleanup.sh --check",
    "cleanup:fast": "./bin/cleanup.sh --fast",
    "db:export": "drizzle-kit export --sql --dialect postgresql",
    "db:generate": "mantle db generate",
    "deploy:staging": "mantle deploy --stage staging",
    "deploy:check": "./bin/pre-deploy-check.sh",
    "deploy:check:production": "./bin/pre-deploy-check.sh --env production",
    "deploy:check:staging": "./bin/pre-deploy-check.sh --env staging",
    "deploy:production": "mantle deploy --stage production",
    "deps:check": "dependency-cruiser src --config .dependency-cruiser.cjs",
    "deps:graph": "dependency-cruiser src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dependency-graph.svg",
    "deps:report": "dependency-cruiser src --config .dependency-cruiser.cjs --output-type html --output-to dependency-report.html",
    "document:terraform": "terraform-docs markdown infra/ > docs/terraform.md",
    "extract:cookies:chrome": "node scripts/extract-youtube-cookies-chrome.mjs",
    "format": "dprint fmt",
    "format:bash": "shfmt -i 2 -ci -sr -w bin/*.sh",
    "format:bash:check": "shfmt -i 2 -ci -sr -d bin/*.sh",
    "format:check": "dprint check",
    "generate:llms": "cat README.md docs/wiki/**/*.md > docs/llms-full.txt",
    "generate:openapi": "mantle generate openapi --schema-prefix 'Models.' --title 'Offline Media Downloader API' --output docs/api/openapi.yaml --html docs/api/index.html",
    "graphrag:extract": "node --import tsx graphrag/extract.ts",
    "graphrag:query": "pnpm dlx tsx graphrag/query.ts",
    "graphrag:validate": "node --import tsx graphrag/validate-metadata.ts",
    "index:codebase": "node --import tsx scripts/indexCodebase.ts",
    "install:prod": "pnpm install --prod",
    "lint": "eslint -c ./eslint.config.mjs .",
    "lint:bash": "shellcheck bin/*.sh .github/scripts/*.sh",
    "lint:fix": "eslint -c ./eslint.config.mjs . --fix",
    "lint:workflows": "actionlint",
    "localstack:health": "curl -s http://localhost:4566/_localstack/health | jq",
    "localstack:logs": "docker compose -f docker-compose.localstack.yml logs -f localstack",
    "localstack:start": "docker compose -f docker-compose.localstack.yml up -d",
    "localstack:stop": "docker compose -f docker-compose.localstack.yml down",
    "pack:context": "repomix",
    "pack:light": "repomix --include \"src/**/*.ts,docs/**/*.md,AGENTS.md\" --ignore \"**/*.test.ts,**/*.spec.ts\"",
    "plan:staging": "mantle deploy --stage staging --dry-run",
    "plan:production": "mantle deploy --stage production --dry-run",
    "precheck": "tsc --noEmit && pnpm run lint && pnpm run format:check",
    "typecheck": "tsc --noEmit",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "scaffold:test": "node --import tsx scripts/scaffoldTest.ts",
    "search:codebase": "node --import tsx scripts/searchCodebase.ts",
    "state:verify": "./bin/verify-state.sh",
    "state:verify:production": "./bin/verify-state.sh --env production",
    "state:verify:staging": "./bin/verify-state.sh --env staging",
    "test": "export LOG_LEVEL=${LOG_LEVEL:-SILENT} && vitest run --config vitest.config.mts",
    "test:eslint:rules": "node eslint-local-rules/test/no-direct-aws-sdk-import.test.cjs && node eslint-local-rules/test/no-domain-leakage.test.cjs && node eslint-local-rules/test/use-entity-mock-helper.test.cjs && node eslint-local-rules/test/integration-test-localstack.test.cjs && node eslint-local-rules/test/aws-sdk-mock-pattern.test.cjs",
    "test:integration": "export LOG_LEVEL=${LOG_LEVEL:-SILENT} POWERTOOLS_LOG_LEVEL=${POWERTOOLS_LOG_LEVEL:-SILENT} NODE_NO_WARNINGS=1 && USE_LOCALSTACK=true vitest run --config vitest.integration.config.mts",
    "test:mutation": "stryker run",
    "test:mutation:auth": "stryker run --mutate 'src/lambdas/standalone/ApiGatewayAuthorizer/**/*.ts,src/lambdas/api/user/**/*.ts'",
    "test:mutation:incremental": "stryker run --incremental",
    "test:remote:hook:production": "./bin/test-hook.sh --env production",
    "test:remote:hook:staging": "./bin/test-hook.sh --env staging",
    "test:remote:list:production": "./bin/test-list.sh --env production",
    "test:remote:list:staging": "./bin/test-list.sh --env staging",
    "test:remote:register:device:production": "./bin/test-registerDevice.sh --env production",
    "test:remote:register:device:staging": "./bin/test-registerDevice.sh --env staging",
    "update:agents:prs": "./bin/update-agents-prs.sh",
    "update:ffmpeg": "./bin/update-ffmpeg.sh",
    "update:ffmpeg:check": "./bin/update-ffmpeg.sh --check-only",
    "update:ytdlp": "./bin/update-yt-dlp.sh",
    "update:ytdlp:check": "./bin/update-yt-dlp.sh --check-only",
    "validate:env-vars": "node ../mantle/packages/cli/dist/index.mjs check env-vars",
    "validate:doc:sync": "./bin/validate-doc-sync.sh",
    "validate:docs": "./bin/validate-docs.sh",
    "validate:docs:freshness": "./bin/validate-docs-freshness.sh",
    "validate:graphrag": "./bin/validate-graphrag.sh",
    "check:conventions": "node ../mantle/packages/cli/dist/index.mjs check --severity HIGH"
  },
  "author": "Jonathan Lloyd",
  "dependencies": {
    "@mantleframework/auth": "link:../mantle/packages/auth",
    "@mantleframework/aws": "link:../mantle/packages/aws",
    "@mantleframework/core": "link:../mantle/packages/core",
    "@mantleframework/database": "link:../mantle/packages/database",
    "@mantleframework/env": "link:../mantle/packages/env",
    "@mantleframework/errors": "link:../mantle/packages/errors",
    "@mantleframework/observability": "link:../mantle/packages/observability",
    "@mantleframework/resilience": "link:../mantle/packages/resilience",
    "@mantleframework/security": "link:../mantle/packages/security",
    "@mantleframework/validation": "link:../mantle/packages/validation",
    "@octokit/rest": "^22.0.1",
    "apns2": "12.2.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "sideEffects": false,
  "imports": {
    "#db/*": "./src/db/*",
    "#domain/*": "./src/domain/*",
    "#services/*": "./src/services/*",
    "#integrations/*": "./src/integrations/*",
    "#errors/*": "./src/errors/*",
    "#utils/*": "./src/utils/*",
    "#entities/*": "./src/entities/*",
    "#lambdas/*": "./src/lambdas/*",
    "#util/*": "./src/util/*",
    "#config/*": "./src/config/*",
    "#types/*": "./src/types/*",
    "#test/*": "./test/*"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "3.1029.0",
    "@aws-sdk/client-dynamodb": "3.1029.0",
    "@aws-sdk/client-eventbridge": "3.1029.0",
    "@aws-sdk/client-lambda": "3.1029.0",
    "@aws-sdk/client-s3": "3.1029.0",
    "@aws-sdk/client-sns": "3.1029.0",
    "@aws-sdk/client-sqs": "3.1029.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@huggingface/transformers": "^4.0.1",
    "@lancedb/lancedb": "^0.27.2",
    "@mantleframework/cli": "link:../mantle/packages/cli",
    "@mantleframework/eslint-config": "link:../mantle/packages/eslint-config",
    "@mantleframework/testing": "link:../mantle/packages/testing",
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@swc/core": "^1.15.26",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^7.0.1",
    "dependency-cruiser": "^17.3.10",
    "dprint": "^0.54.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "istanbul-lib-instrument": "^6.0.3",
    "mock-jwks": "^3.3.5",
    "puppeteer-core": "^24.40.0",
    "repomix": "^1.13.1",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "unbuild": "^3.6.1",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vitest-monocart-coverage": "^4.0.2"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1",
      "drizzle-zod>zod": "^4.3.4",
      "esbuild": ">=0.27.4",
      "undici-types": "7.16.0"
    },
    "onlyBuiltDependencies": [
      "@modelcontextprotocol/ext-apps",
      "@swc/core",
      "core-js",
      "dprint",
      "esbuild",
      "msw",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "auditConfig": {
      "ignoreCves": [
        "GHSA-46wh-pxpv-q5gq"
      ]
    }
  }
}
